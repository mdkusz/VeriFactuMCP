{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec/json/invoice-draft-create.schema.json",
  "title": "InvoiceDraftCreate",
  "type": "object",
  "required": ["mode", "issueDate", "series"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["verifactu", "no_verifactu"],
      "description": "verifactu: intended to be submitted as VeriFactu. no_verifactu: intended for non-VeriFactu validation flow."
    },
    "issueDate": { "$ref": "common-types.schema.json#/$defs/date" },
    "series": {
      "type": "string",
      "minLength": 1,
      "description": "Invoice series used by the issuer (e.g., 'A', '2026')."
    },
    "number": {
      "type": "string",
      "minLength": 1,
      "description": "Optional initial number. If omitted, server may assign."
    },
    "currency": {
      "type": "string",
      "default": "EUR",
      "minLength": 3,
      "maxLength": 3
    },
    "notes": { "type": "string" },
    "clientRef": {
      "type": "string",
      "description": "Optional idempotency/client correlation key."
    }
  },
  "additionalProperties": false
}
