{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec/json/invoice-snapshot.schema.json",
  "title": "InvoiceSnapshot",
  "type": "object",
  "required": [
    "snapshotId",
    "mode",
    "series",
    "number",
    "issueDate",
    "issuer",
    "recipient",
    "lines",
    "totals",
    "status"
  ],
  "properties": {
    "snapshotId": { "$ref": "common-types.schema.json#/$defs/uuid" },

    "mode": { "type": "string", "enum": ["verifactu", "no_verifactu"] },
    "series": { "type": "string", "minLength": 1 },
    "number": { "type": "string", "minLength": 1 },
    "issueDate": { "$ref": "common-types.schema.json#/$defs/date" },
    "currency": { "type": "string", "default": "EUR", "minLength": 3, "maxLength": 3 },

    "issuer": { "$ref": "common-types.schema.json#/$defs/party" },
    "recipient": { "$ref": "common-types.schema.json#/$defs/party" },

    "rectification": {
      "type": ["object", "null"],
      "properties": {
        "rectifiesSnapshotId": { "$ref": "common-types.schema.json#/$defs/uuid" },
        "reason": { "type": "string" }
      },
      "required": ["rectifiesSnapshotId", "reason"],
      "additionalProperties": false
    },

    "sif": {
      "type": ["object", "null"],
      "properties": {
        "systemId": { "type": "string" },
        "systemVersion": { "type": "string" },
        "installationNumber": { "type": "string" }
      },
      "additionalProperties": false
    },

    "lines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/line" }
    },

    "totals": {
      "type": "object",
      "required": ["netAmount", "taxAmount", "grossAmount"],
      "properties": {
        "netAmount": { "$ref": "common-types.schema.json#/$defs/money" },
        "taxAmount": { "$ref": "common-types.schema.json#/$defs/money" },
        "grossAmount": { "$ref": "common-types.schema.json#/$defs/money" }
      },
      "additionalProperties": false
    },

    "hashChain": {
      "type": ["object", "null"],
      "description": "Computed hash footprint / chaining fields. Exact computation is per AEAT specification.",
      "properties": {
        "algorithm": { "type": "string", "default": "SHA-256" },
        "currentHash": { "type": "string" },
        "previousHash": { "type": "string" }
      },
      "additionalProperties": false
    },

    "qr": {
      "type": ["object", "null"],
      "description": "Derived QR info for invoice printing/visualization.",
      "properties": {
        "qrUrl": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "xml": {
      "type": ["object", "null"],
      "description": "Optional storage of generated XML artifacts.",
      "properties": {
        "verifactuXml": { "type": "string", "description": "Raw XML text." },
        "signedXml": { "type": "string", "description": "Raw XML text with signature, if applicable." }
      },
      "additionalProperties": false
    },

    "status": {
      "type": "string",
      "enum": ["Finalized", "Submitted", "Accepted", "Rejected"]
    },

    "aeat": {
      "type": ["object", "null"],
      "description": "AEAT submission/consultation metadata.",
      "properties": {
        "csv": { "type": "string" },
        "submittedAt": { "$ref": "common-types.schema.json#/$defs/dateTime" },
        "acceptedAt": { "$ref": "common-types.schema.json#/$defs/dateTime" },
        "rejectedAt": { "$ref": "common-types.schema.json#/$defs/dateTime" },
        "errors": {
          "type": "array",
          "items": { "$ref": "common-types.schema.json#/$defs/error" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "line": {
      "type": "object",
      "required": ["lineId", "description", "quantity", "unitPrice", "netAmount"],
      "properties": {
        "lineId": { "$ref": "common-types.schema.json#/$defs/uuid" },
        "description": { "type": "string", "minLength": 1 },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "taxRate": { "$ref": "common-types.schema.json#/$defs/percent" },
        "netAmount": { "$ref": "common-types.schema.json#/$defs/money" },
        "taxAmount": { "$ref": "common-types.schema.json#/$defs/money" },
        "grossAmount": { "$ref": "common-types.schema.json#/$defs/money" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
